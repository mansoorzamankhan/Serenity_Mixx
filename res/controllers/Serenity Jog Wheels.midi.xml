<?xml version="1.0" encoding="utf-8"?>
<MixxxMIDIPreset schemaVersion="1" mixxxVersion="2.5+">
  <info>
    <name>Serenity Jog Wheels</name>
    <author>Serenity DJ System</author>
    <description>Maps the Serenity hardware's two RPi GPIO optical rotary encoders (read via libgpiod and republished as MIDI CC over an ALSA virtual port by SerenityGpioJogWheelService) to the Deck A and Deck B jog wheels. See SERENITY.md for the GPIO pinout.</description>
  </info>
  <controller id="Serenity Jog Wheels">
    <scriptfiles>
      <file functionprefix="SerenityJogWheels" filename="Serenity-Jog-Wheels-scripts.js"/>
    </scriptfiles>
    <controls>
      <control>
        <group>[Channel1]</group>
        <key>SerenityJogWheels.deckJog</key>
        <status>0xB0</status>
        <midino>0x01</midino>
        <options>
          <script-binding/>
        </options>
      </control>
      <control>
        <group>[Channel2]</group>
        <key>SerenityJogWheels.deckJog</key>
        <status>0xB0</status>
        <midino>0x02</midino>
        <options>
          <script-binding/>
        </options>
      </control>
    </controls>
  </controller>
</MixxxMIDIPreset>
